
SELECT 
    CAST(O.BRANCH_NAME AS VARCHAR(50)) || '-' || CAST(M.ORIGINAL_BRANCH AS VARCHAR(7)) 
        AS PO_CREATEBRANCH,

    M.CUSTOMER_ID AS PO_INTCUSTID,
    M.EXTERNAL_CUSTOMER_ID AS PO_EXTCUSTID,

    H.NATIONAL_CODE AS PO_NATIONALCODE,
    CAST(H.ID_SERIES AS VARCHAR(5)) AS PO_SERI_MELI,
    CAST(H.ID_SERIAL AS VARCHAR(10)) AS PO_SERIAL_MELI,

    CAST(H.FIRST_NAME AS VARCHAR(30)) AS PO_NAME,
    CAST(H.LAST_NAME AS VARCHAR(30)) AS PO_FAMILY,

    H.BIRTH_DATE AS PO_BIRTHDATE,

    H.FOLLOW_CODE AS PO_FOLLOWCODE

FROM CUSTOMER_MASTER M
INNER JOIN CUSTOMER_PERSONAL H
    ON M.CUSTOMER_ID = H.CUSTOMER_ID

INNER JOIN ORGANIZATION_BRANCH O
    ON M.ORIGINAL_BRANCH = O.BRANCH_ID

LEFT JOIN CUSTOMER_EXTRA_INFO Z
    ON M.CUSTOMER_ID = Z.CUSTOMER_ID

WHERE 
    M.EXTERNAL_CUSTOMER_ID = :PI_ExtCustId
    OR M.CUSTOMER_ID = :PI_IntCustId
;
